APP_ENV=development
APP_NAME=BuyerReach
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql+psycopg://buyerreach:buyerreach@postgres:5432/buyerreach
POSTGRES_USER=buyerreach
POSTGRES_PASSWORD=buyerreach
POSTGRES_DB=buyerreach
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-32-byte-minimum

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=buyerreach
MINIO_SECRET_KEY=buyerreach-secret
MINIO_ROOT_USER=buyerreach
MINIO_ROOT_PASSWORD=buyerreach-secret
MINIO_BUCKET=buyerreach

FEISHU_WEBHOOK_URL=
PROVIDER_SEARCH_API_KEY=
PROVIDER_CONTACT_API_KEY=
PROVIDER_EMAIL_FINDER_API_KEY=
PROVIDER_EMAIL_VERIFIER_API_KEY=

# Portable internal email verifier. Store the same token through System Settings.
VERIFIER_TOKEN=change-me-local-verifier-token
SMTP_ENABLED=true
SMTP_PROXY_URL=
SMTP_FROM_EMAIL=verify@example.org
SMTP_HELLO_NAME=localhost
REQUEST_TIMEOUT=25s
SMTP_CONNECT_TIMEOUT=8s
SMTP_OPERATION_TIMEOUT=8s
MAX_CONCURRENCY=10
DOMAIN_CONCURRENCY=1

# Required by scripts/backup.sh and scripts/restore.sh. Keep this outside version control.
BACKUP_PASSPHRASE=
